/* ======================== UI HELPERS + MAIN SCREEN ======================= */

static inline int TW(const char* s, FontDef font) {
    return (int)strlen(s) * (int)font.FontWidth;
}

static void DrawCentered(const char* s, int y, FontDef font) {
    int x = (SSD1306_WIDTH - TW(s, font)) / 2;
    if (x < 0) x = 0;
    ssd1306_SetCursor(x, y);
    ssd1306_WriteString(s, font, White);
}

static void DrawBattery(int x, int y, int w, int h, uint8_t pct) {
    if (w < 8) w = 8;
    if (h < 8) h = 8;
    if (pct > 100) pct = 100;

    /* ramka */
    ssd1306_DrawRectangle(x, y, x + w - 3, y + h - 1, White);
    /* bolec plusa po prawej */
    ssd1306_Line(x + w - 2, y + h / 3, x + w - 2, y + (2 * h) / 3, White);

    /* wypełnienie */
    int inner_w = (w - 3) - 2;
    int inner_h = (h - 1) - 2;
    int fill_w  = (inner_w * pct) / 100;
    if (fill_w > 0) {
        ssd1306_FillRectangle(x + 2, y + 1, x + 2 + fill_w, y + 1 + inner_h, White);
    }
}

static uint8_t BatteryPctFromV(float v) {
    float pct = (v - BAT_EMPTY_V) * 100.0f / (BAT_FULL_V - BAT_EMPTY_V);
    if (pct < 0) pct = 0;
    if (pct > 100) pct = 100;
    return (uint8_t)pct;
}

static void DrawLabelValue(int x, int y, const char* label, const char* value) {
    ssd1306_SetCursor(x, y);
    ssd1306_WriteString(label, Font_6x8, White);
    ssd1306_SetCursor(x, y + 8 + 2);
    ssd1306_WriteString(value, Font_7x10, White);
}

/* główny ekran: PAS + bateria + separator + duża prędkość + km/h + dół PWR/VOLT/TRIP */
void renderMainScreen(void)
{
    char buf[32];

    /* górny pasek */
    ssd1306_SetCursor(2, 1);
    snprintf(buf, sizeof(buf), "PAS %u", supportLevel);
    ssd1306_WriteString(buf, Font_6x8, White);

    uint8_t bpct = BatteryPctFromV(batteryVoltage);
    DrawBattery(SSD1306_WIDTH - 26, 0, 24, 10, bpct);

    /* separator */
    ssd1306_Line(0, 12, SSD1306_WIDTH - 1, 12, White);

    /* duża prędkość */
    snprintf(buf, sizeof(buf), "%.0f", speed);
    /* jeśli masz Font_16x26 w swojej bibliotece, zmień tutaj na Font_16x26 */
    DrawCentered(buf, 16, Font_11x18);
    DrawCentered("km/h", 16 + 18 + 2, Font_7x10);

    /* dolny pasek */
    ssd1306_Line(0, SSD1306_HEIGHT - 20, SSD1306_WIDTH - 1, SSD1306_HEIGHT - 20, White);

    int col1_x = 2;
    int col2_x = (SSD1306_WIDTH / 2) - 22;
    int col3_x = SSD1306_WIDTH - 48;
    int base_y = SSD1306_HEIGHT - 18;

    snprintf(buf, sizeof(buf), "%.0f W", power);
    DrawLabelValue(col1_x, base_y, "PWR", buf);

    snprintf(buf, sizeof(buf), "%.1f V", batteryVoltage);
    DrawLabelValue(col2_x, base_y, "VOLT", buf);

    snprintf(buf, sizeof(buf), "%.1f km", totalDistance);
    DrawLabelValue(col3_x, base_y, "TRIP", buf);

    ssd1306_UpdateScreen();
}

