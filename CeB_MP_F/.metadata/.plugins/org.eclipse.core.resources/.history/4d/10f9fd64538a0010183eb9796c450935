/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */
//  PID_TypeDef PID;
  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  HAL_Init();

  /* USER CODE BEGIN Init */
//  PID_Init(&PID);
  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_I2C1_Init();
  MX_I2C2_Init();
  MX_TIM1_Init();
  MX_USART1_UART_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  MX_TIM4_Init();
  MX_TIM9_Init();
  MX_IWDG_Init();

  /* Initialize interrupts */
  MX_NVIC_Init();
  /* USER CODE BEGIN 2 */

  ///////////////////////////////// NTC10K / NTC10KS timers
  HAL_TIM_Base_Start_IT(&htim4);
  HAL_TIM_Base_Start_IT(&htim4);

  /////////////////////////////// NEO6GPS
  NEO6_Init(&GpsState, &huart1);

  ///////////////////////////// ACS758
  ACS7XX Serch;
  ACS7XX_ResetCounters(&Serch);
  ACS7XX_Calibrate(&Serch);
  ACS7XX_Init_Default(&Serch);

  ///////////////////////////// HALL SPEED
  HAL_TIM_IC_START();

  ///////////////////////////// SSD1306
  ssd1306_Init();

  ///////////////////////////// BUTTONS
  Button_Init(&BUTTON1_Pin, BUTTON1_Pin_GPIO_Port, BUTTON1_Pin_Pin, 30, 3000, 700);
  Button_Init(&BUTTON2_Pin, BUTTON2_Pin_GPIO_Port, BUTTON2_Pin_Pin, 30, 3000, 700);
  Button_Init(&BUTTON3_Pin, BUTTON3_Pin_GPIO_Port, BUTTON3_Pin_Pin, 30, 3000, 700);

  ///////////////////////////// PID init (power control)
  PID_Init_Power(&Serch, &hadc1, &powerPercentage, &averageVoltagePercentage);

  ///////////////////////////// Delays
  uint32_t GPS_delay = 0;
  uint32_t mAhWh_delay = 0;
  uint32_t NTC10K_delay = 0;
  uint32_t NTC10KS_delay = 0;
  uint32_t POWER_delay = 0;
  uint32_t ACS758_delay = 0;
  uint32_t V_BAT_delay = 0;
  uint32_t SSD1306_delay = 0;
  uint32_t BUTTON_delay = 0;

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    if(HAL_IWDG_Refresh(&hiwdg) != HAL_OK)
    {
      Error_Handler();
    }

    /* NEO6GPS */
    if((HAL_GetTick() - GPS_delay) > 100)
    {
      NEO6_Task(&GpsState);
      NEO6_IsFix(&GpsState);
      GPS_delay = HAL_GetTick();
    }

    /* mAh / Wh */
    if((HAL_GetTick() - mAhWh_delay) > 1000)
    {
      UpdateBatteryConsumption(&Serch, &hadc1, &batteryCurrentCapacityAh, &batteryCurrentCapacityWh);
      mAhWh_delay = HAL_GetTick();
    }

    /* PWM Throttle (Power) – wywołanie ciągłe */
    Throttle_Control_Power(&Serch, &hadc1, &htim3, TIM_CHANNEL_2, &averageVoltagePercentage, &powerPercentage);

    /* NTC10K */
    if((HAL_GetTick() - NTC10K_delay) > 1000)
    {
      if(Sch_100ms)
      {
        NTC10K_ADC_Read(&ADC_Raw);
        NTC10K_Get_Avg_Temp(&Avg_Tmp);
      }
      NTC10K_delay = HAL_GetTick();
    }

    /* NTC10KS */
    if((HAL_GetTick() - NTC10KS_delay) > 1000)
    {
      if(Sch_100ms_S)
      {
        NTC10K_ADC_Read_S(&ADC_Raw_S);
        NTC10K_Get_Avg_Temp_S(&Avg_Tmp_S);
      }
      NTC10KS_delay = HAL_GetTick();
    }

    /* Hall speed timeout */
    if (HAL_GetTick() - lastImpulseTime >= TIMEOUT)
    {
      pulseCounter = 0;
      speed = 0;
      rotational_speed = 0;
    }

    /* Power calculation */
    if((HAL_GetTick() - POWER_delay) > 500)
    {
      Power_Calculate(&Serch, &hadc1, &power);
      POWER_delay = HAL_GetTick();
    }

    /* ACS758 */
    if((HAL_GetTick() - ACS758_delay) > 500)
    {
      ACS7XX_InstantCurrent(&Serch, &current, &voltage, &value);
      ACS758_delay = HAL_GetTick();
    }

    /* Battery voltage */
    if((HAL_GetTick() - V_BAT_delay) > 1000)
    {
      HAL_ADC_Start(&hadc1);
      HAL_ADC_PollForConversion(&hadc1, HAL_MAX_DELAY);
      Battery_Get_ADC_Value(&hadc1, &bat_adc_val);
      Battery_Get_Voltage(&hadc1 , &batteryVoltage);
      HAL_ADC_Stop(&hadc1);
      V_BAT_delay = HAL_GetTick();
    }

    /* SSD1306 draw */
    if((HAL_GetTick() - SSD1306_delay) > 100)
    {
      char displayBuffer[50];

      ssd1306_Fill(Black);

      switch (pageIndex)
      {
        case 0: // Ekran główny (nowy layout)
          renderMainScreen();
          break;

        case 1: // Możesz też użyć głównego lub własnej strony
          renderMainScreen();
          break;

        case 2:
          renderPage3(displayBuffer);
          break;

        case 3:
          renderPage4(displayBuffer);
          break;

        case 4:
          renderPage5(displayBuffer);
          break;

        case 5:
          renderPage6(displayBuffer);
          break;

        default:
          pageIndex = 0;
      }

      SSD1306_delay = HAL_GetTick();
    }

    /* Buttons */
    if((HAL_GetTick() - BUTTON_delay) > 100)
    {
      if (Button_IsPressed(&BUTTON1_Pin))
      {
        if (pageIndex >= 5) pageIndex = 0;
        else pageIndex++;
      }

      if (Button_IsPressed(&BUTTON2_Pin))
      {
        if (supportLevel <= 4) supportLevel++;
      }

      if (Button_IsPressed(&BUTTON3_Pin))
      {
        if (supportLevel >= 1) supportLevel--;
      }

      BUTTON_delay = HAL_GetTick();
    }

    /* USER CODE END WHILE */
    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

